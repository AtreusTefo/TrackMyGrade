<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <sectionGroup name="elmah">
      <section name="security" requirePermission="false" type="Elmah.SecuritySectionHandler, Elmah"/>
      <section name="errorFilter" requirePermission="false" type="Elmah.ErrorFilterSectionHandler, Elmah"/>
      <section name="errorMail" requirePermission="false" type="Elmah.ErrorMailSectionHandler, Elmah"/>
      <section name="errorLog" requirePermission="false" type="Elmah.ErrorLogSectionHandler, Elmah"/>
    </sectionGroup>
  </configSections>

  <connectionStrings>
    <add name="DefaultConnection" connectionString="Server=(local);Database=TrackMyGradeDB;Trusted_Connection=true;" providerName="System.Data.SqlClient"/>
  </connectionStrings>

  <elmah>
    <!-- ELMAH security settings -->
    <security allowRemoteAccess="false"/>

    <!-- Error log configuration - stores errors in memory -->
    <errorLog type="Elmah.MemoryErrorLog, Elmah" size="100"/>
    
    <!-- Alternative: Store errors in SQL Server
    <errorLog type="Elmah.SqlErrorLog, Elmah" connectionStringName="DefaultConnection"/>
    -->

    <!-- Error mail configuration - uncomment to enable email notifications -->
    <!-- 
    <errorMail 
      from="error@yourdomain.com" 
      to="admin@yourdomain.com" 
      subject="TrackMyGrade API Error"
      smtpServer="smtp.yourdomain.com"
      smtpPort="587"
      useSsl="true"
      userName="your-email@domain.com"
      password="your-password"/>
    -->

    <!-- Error filtering configuration -->
    <errorFilter>
      <test>
        <eq binding="HttpStatusCode" value="404" type="Int32"/>
      </test>
    </errorFilter>
  </elmah>

  <system.webServer>
    <validation validateIntegratedModeConfiguration="false"/>

    <modules runAllManagedModulesForAllRequests="true">
      <!-- ELMAH modules for error logging and web access -->
      <add name="ErrorLog" type="Elmah.ErrorLogModule, Elmah"/>
      <add name="ErrorMail" type="Elmah.ErrorMailModule, Elmah"/>
      <add name="ErrorFilter" type="Elmah.ErrorFilterModule, Elmah"/>
    </modules>

    <handlers>
      <!-- ELMAH error log viewer endpoint -->
      <add name="Elmah" path="elmah.axd" verb="POST,GET,HEAD" type="Elmah.ErrorLogPageFactory, Elmah" preCondition="integratedMode"/>
    </handlers>

    <httpErrors errorMode="Custom" existingResponse="PassThrough"/>
  </system.webServer>

  <system.web>
    <httpModules>
      <!-- ELMAH modules -->
      <add name="ErrorLog" type="Elmah.ErrorLogModule, Elmah"/>
      <add name="ErrorMail" type="Elmah.ErrorMailModule, Elmah"/>
      <add name="ErrorFilter" type="Elmah.ErrorFilterModule, Elmah"/>
    </httpModules>

    <httpHandlers>
      <!-- ELMAH error log viewer -->
      <add verb="POST,GET,HEAD" path="elmah.axd" type="Elmah.ErrorLogPageFactory, Elmah"/>
    </httpHandlers>

    <compilation debug="true" targetFramework="4.8"/>
    <httpRuntime targetFramework="4.8"/>
  </system.web>

  <!-- Authorization for ELMAH - restrict access to error log viewer -->
  <location path="elmah.axd">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow users="*"/>
      </authorization>
    </system.web>
  </location>
</configuration>

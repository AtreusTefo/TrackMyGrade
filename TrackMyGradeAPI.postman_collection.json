				{
					"name": "Register Teacher",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test that registration was successful",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Parse response",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    ",
									"    // Validate response structure",
									"    pm.test(\"Response has id\", function () {",
									"        pm.expect(jsonData).to.have.property('id');",
									"    });",
									"    ",
									"    pm.test(\"Response has email\", function () {",
									"        pm.expect(jsonData).to.have.property('email');",
									"    });",
									"    ",
									"    pm.test(\"Response has token\", function () {",
									"        pm.expect(jsonData).to.have.property('token');",
									"    });",
									"    ",
									"    // Save teacher ID to environment for subsequent requests",
									"    pm.environment.set(\"teacherId\", jsonData.id);",
									"    pm.environment.set(\"authToken\", jsonData.token);",
									"    ",
									"    console.log(\"Teacher registered successfully with ID: \" + jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
